{
  "$schema": "https://schemas.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default capabilities for the MCDF Marketplace app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:scope-read-recursive",
    "dialog:default",
    "dialog:allow-open"
  ]
}
