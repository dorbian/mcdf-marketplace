{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MCDF Marketplace",
  "version": "0.1.0",
  "identifier": "com.mcdf.marketplace",
  "build": {
    "beforeBuildCommand": "pnpm run build",
    "beforeDevCommand": "pnpm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "MCDF Marketplace",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["$DOWNLOAD/*", "$HOME/.mcdf/*"],
        "deny": []
      }
    },
    "http": {
      "scope": {
        "allow": [{ "url": "http://localhost:*" }, { "url": "https://*/*" }]
      }
    },
    "shell": {
      "open": true
    }
  }
}